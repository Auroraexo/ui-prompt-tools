ARK_API_KEY=YOUR_ARK_API_KEY_HERE

# 可选：自定义后端服务端口（不配置则使用 5180）
# AI_SERVER_PORT=5180

# 可选：自定义豆包模型 ID，默认为后端代码中的 doubao-seed-1-6-251015
# ARK_MODEL_ID=your-model-id-here

# ==================== PostgreSQL 数据库配置 ====================
# 配置持久化功能需要 PostgreSQL 数据库
# 如果你想使用配置保存/加载功能，请配置以下参数（以下为完全不可用的占位示例，请自行替换为你的数据库信息）

POSTGRES_HOST=example-host
POSTGRES_PORT=5432
POSTGRES_DB=example_db
POSTGRES_USER=example_user
POSTGRES_PASSWORD=example_password
