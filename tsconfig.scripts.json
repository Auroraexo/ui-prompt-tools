{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true
  },
  "include": ["scripts/**/*.ts", "scripts/**/*.mts", "src/storage/**/*.ts", "src/utils/**/*.ts", "src/data/**/*.ts"]
}

